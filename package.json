{
  "name": "leapnux-5nux-monorepo",
  "version": "0.4.1-alpha.1",
  "description": "5-NUX — OSS anchor product for the LeapNuX methodology. Monorepo containing rootnux, trunknux, branchnux, leafnux, fruitnux + 6nux-core shared lib + 5nux meta-package.",
  "private": true,
  "license": "Apache-2.0",
  "author": "Chu Ling",
  "repository": {
    "type": "git",
    "url": "https://github.com/StillNotBald/branchnux.git"
  },
  "homepage": "https://github.com/StillNotBald/branchnux#readme",
  "bugs": {
    "url": "https://github.com/StillNotBald/branchnux/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspace=@leapnux/branchnux",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "lint:templates": "npm run lint:templates --workspace=@leapnux/branchnux"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "vitest": "^4.1.5"
  }
}
